<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevOps Sprint - Day 88</title>
    <style>
        body { background: #0f172a; color: #38bdf8; font-family: 'Courier New', monospace; padding: 30px; text-align: center; }
        .container { max-width: 600px; margin: auto; border: 2px solid #38bdf8; padding: 20px; box-shadow: 0 0 15px #38bdf8; border-radius: 8px; }
        input, button { padding: 10px; margin: 10px 0; width: 90%; border-radius: 4px; border: 1px solid #38bdf8; background: #1e293b; color: #fff; }
        button { background: #38bdf8; color: #0f172a; font-weight: bold; cursor: pointer; }
        button:hover { background: #0ea5e9; }
        .user-card { background: #1e293b; padding: 10px; margin: 10px 0; border-left: 5px solid #34d399; text-align: left; border-radius: 4px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>🚀 DEVOPS SPRINT: DAY 90</h1>
        <p>Server Environment: <strong>$ENV_NAME</strong></p>
        <hr style="border-color: #38bdf8;">
        
        <h3>Add New Cluster Profile</h3>
        <input type="text" id="name" placeholder="Enter Name (e.g., Nikhil)">
        <input type="text" id="role" placeholder="Enter Role (e.g., DevOps Engineer)">
        <button onclick="saveData()">Write Data to MongoDB</button>

        <hr style="border-color: #38bdf8;">
        
        <h3>Live Cluster Profiles</h3>
        <div id="usersList">Loading data paths...</div>
    </div>

    <script>
        // 1. Fetch and Display Data on Load
        async function fetchUsers() {
            try {
                const res = await fetch('/api/users');
                const data = await res.json();
                const listDiv = document.getElementById('usersList');
                listDiv.innerHTML = '';
                
                if(data.length === 0) { listDiv.innerHTML = 'No records in database volume.'; return; }
                
                data.forEach(user => {
                    listDiv.innerHTML += `
                        <div class="user-card">
                            <strong>👤 ${user.name}</strong> - ${user.role} <br>
                            <small style="color:#64748b">Logged on Day: ${user.day} | ${new Date(user.createdAt).toLocaleTimeString()}</small>
                        </div>`;
                });
            } catch (err) {
                document.getElementById('usersList').innerHTML = 'Network lookup failed: ' + err.message;
            }
        }

        // 2. Submit Form Data to Backend
        async function saveData() {
            const name = document.getElementById('name').value;
            const role = document.getElementById('role').value;
            if(!name || !role) { alert('Fill fields laale!'); return; }

            try {
                const res = await fetch('/api/users', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, role, day: 88 })
                });
                if(res.ok) {
                    document.getElementById('name').value = '';
                    document.getElementById('role').value = '';
                    fetchUsers(); // Refresh display grid instantly
                }
            } catch (err) {
                alert('Write failed: ' + err.message);
            }
        }

        // Initialize grid trigger
        fetchUsers();
    </script>
</body>
</html>
