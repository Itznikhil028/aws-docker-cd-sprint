<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>${APP_TITLE} | Day 79</title>
    <style>
        body {
            background: #0b0f19;
            color: #ffffff;
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .dynamic-card {
            background: #111827;
            padding: 3rem;
            border-radius: 16px;
            box-shadow: 0 0 35px ${NEON_COLOR};
            border: 1px solid ${NEON_COLOR};
            text-align: center;
            max-width: 450px;
        }
        h1 {
            color: ${NEON_COLOR};
            font-size: 2.5rem;
            margin: 0 0 0.5rem 0;
        }
        .branch-text {
            color: #9ca3af;
            font-size: 1.1rem;
            margin-bottom: 1.5rem;
        }
        .status-badge {
            background: rgba(255, 255, 255, 0.05);
            padding: 0.5rem 1.2rem;
            border-radius: 50px;
            font-family: monospace;
            border-left: 3px solid ${NEON_COLOR};
        }
    </style>
</head>
<body>
    <div class="dynamic-card">
        <h1>${APP_TITLE}</h1>
        <div class="branch-text">${ACADEMIC_BRANCH}</div>
        <div class="status-badge">Status: ${DEVOPS_STATUS}</div>
    </div>
</body>
</html>
